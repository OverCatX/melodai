#Generation strategy 
# mock  → offline, instant, no API key required (default)
# suno  → calls api.sunoapi.org, requires SUNO_API_KEY
GENERATOR_STRATEGY=mock

#  Suno API (required when GENERATOR_STRATEGY=suno) 
# Get your Bearer token from https://sunoapi.org
SUNO_API_KEY=

# Google Sign-In: OAuth 2.0 Web client ID (used to verify id_token from the frontend)
# https://console.cloud.google.com/apis/credentials — create OAuth client "Web application"
GOOGLE_OAUTH_CLIENT_ID=

# Default: off — web app uses Google only. Set true to allow POST /api/users/get-or-create/ (curl/Postman only).
# ALLOW_DISPLAY_NAME_GET_OR_CREATE=true
