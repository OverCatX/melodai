#Generation strategy 
# mock  → offline, instant, no API key required (default)
# suno  → calls api.sunoapi.org, requires SUNO_API_KEY
GENERATOR_STRATEGY=mock

#  Suno API (required when GENERATOR_STRATEGY=suno) 
# Get your Bearer token from https://sunoapi.org
SUNO_API_KEY=

# Google OAuth — Web application client (https://console.cloud.google.com/apis/credentials)
# Login flow: GET /api/auth/google/login/ → Google → GET /api/auth/google/callback/
GOOGLE_OAUTH_CLIENT_ID=
# Client secret (server only; required for the browser login flow)
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match an "Authorized redirect URI" in Google Cloud (default matches runserver)
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback/
# Where the API redirects after login (SPA origin, no path)
GOOGLE_OAUTH_FRONTEND_BASE=http://localhost:5173

# Default: off — web app uses Google only. Set true to allow POST /api/users/get-or-create/ (curl/Postman only).
# ALLOW_DISPLAY_NAME_GET_OR_CREATE=true
